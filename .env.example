# NInsideN Environment Variables
# Copy to .env.local for local development — never commit real keys

# ── OpenAI (primary) ──────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# Leave blank to use the polished local fallback (UI still fully works)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Site metadata (sent for attribution)
SITE_URL=http://localhost:3000
SITE_NAME=NInsideN

# ── OpenRouter (legacy, still supported) ──────────────────────────────────
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/auto

# ── Local Next.js dev (without vercel dev) ────────────────────────────────
# BACKEND_URL=http://localhost:8000
